# RPC endpoints
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=
REACTIVE_RPC_URL=https://lasna-rpc.rnk.dev/

# Private keys
SEPOLIA_PRIVATE_KEY=
BASE_PRIVATE_KEY=
REACTIVE_PRIVATE_KEY=

# Owner/deployer
OWNER=

# Chain IDs
SEPOLIA_CHAIN_ID=11155111
BASE_CHAIN_ID=84532
REACTIVE_CHAIN_ID=5318007

# Callback proxies
SEPOLIA_CALLBACK_PROXY=0xc9f36411C9897e7F959D99ffca2a0Ba7ee0D7bDA
BASE_CALLBACK_PROXY=0xa6eA49Ed671B8a4dfCDd34E36b7a75Ac79B8A5a6

# Reactive constants
REACTIVE_SYSTEM_CONTRACT=0x0000000000000000000000000000000000fffFfF
REACTIVE_IGNORE=0xa65f96fc951c35ead38878e0f0b7a3c744a6f5ccc1476b313353ce31712313ad

# Deployment outputs
# Deployment order:
# 1) DeploySepolia.s.sol / forge create source contracts   → fill MOCK_PRICE_FEED, BALANCE_MONITOR
# 2) DeployBaseSepolia.s.sol / forge create VaultExecution → set VAULT_EXECUTION_EXPECTED_RVM_ID to the Reactive deployer wallet / expected RVM ID
# 3) DeployLasna.s.sol / forge create VaultSentinelReactive → fill VAULT_SENTINEL_REACTIVE (Lasna contract address)
# Live callback semantics: VaultSentinelReactive encodes VAULT_EXECUTION_EXPECTED_RVM_ID into executeFromReactive(...), not the sentinel contract address.
MOCK_PRICE_FEED=
BALANCE_MONITOR=
VAULT_EXECUTION=
BASIC_TRANSFER_ADAPTER=
UNISWAP_STOP_ORDER_ADAPTER=
AAVE_PROTECTION_ADAPTER=
VAULT_SENTINEL_REACTIVE=
VAULT_EXECUTION_EXPECTED_RVM_ID=

# External protocols
UNISWAP_ROUTER=
AAVE_POOL=

# Lasna rule bootstrap
# Subscriptions auto-initialize in constructor (guarded by !vm).
# Forge simulation skips them (vm=true), but they execute on-chain (vm=false).
# Use --gas-estimate-multiplier 200 or explicit --gas-limit when broadcasting.
DEFAULT_CALLBACK_GAS=300000
PRICE_RULE_ADAPTER=
DRAIN_RULE_ADAPTER=
PRICE_RULE_GAS=300000
DRAIN_RULE_GAS=300000
PRICE_BELOW_THRESHOLD=180000000000
BALANCE_MIN_THRESHOLD=1000000000000000000
PRICE_RULE_ADAPTER_DATA=0x
DRAIN_RULE_ADAPTER_DATA=0x
